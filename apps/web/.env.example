# =============================================================================
# SimpleInvoice — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# 101Digital OAuth2 — Server-only (never use NEXT_PUBLIC_ prefix)
# Obtain from 101Digital developer portal.
# -----------------------------------------------------------------------------
DIGITAL_CLIENT_ID=your_client_id_here
DIGITAL_CLIENT_SECRET=your_client_secret_here

# -----------------------------------------------------------------------------
# 101Digital API Base URL
# Production: https://api.101digital.io
# Sandbox:    https://sandbox.101digital.io
# -----------------------------------------------------------------------------
DIGITAL_BASE_URL=https://sandbox.101digital.io

# -----------------------------------------------------------------------------
# Cookie settings (optional — defaults used if not set)
# -----------------------------------------------------------------------------
# COOKIE_DOMAIN=localhost
