# =============================================================================
# SimpleInvoice — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# 101Digital OAuth2 — Server-only (never use NEXT_PUBLIC_ prefix)
# Obtain from 101Digital developer portal.
# -----------------------------------------------------------------------------
DIGITAL_CLIENT_ID=your_client_id_here
DIGITAL_CLIENT_SECRET=your_client_secret_here

# -----------------------------------------------------------------------------
# 101Digital API Base URLs
# The auth endpoint (WSO2 IS) and API gateway use different hostnames.
# Auth:    https://is-wso2.101digital.io  (OAuth2 token + membership service)
# API:     https://api.101digital.io      (invoice-service, etc.)
# Sandbox: https://is-wso2-dev.101digital.io / https://api-neobank-dev.101digital.io
# -----------------------------------------------------------------------------
DIGITAL_AUTH_BASE_URL=https://is-wso2-dev.101digital.io
DIGITAL_API_BASE_URL=https://api-neobank-dev.101digital.io

# -----------------------------------------------------------------------------
# Cookie settings (optional — defaults used if not set)
# -----------------------------------------------------------------------------
# COOKIE_DOMAIN=localhost
